<vb:ModuleViewBase x:Class="Plugin.DistanceLL.Views.DistanceLLView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.DistanceLL.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                   xmlns:helper="clr-namespace:HV.Common.Helper;assembly=HV"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.DistanceLL.ViewModels"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   xmlns:hw="clr-namespace:VM.Halcon;assembly=VM.Halcon"
                   Icon="/Plugin.DistanceLL;component/Assets/Images/Tool/DistanceLL.png"
                   Height="680" Width="980"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="基本参数">
                    <Grid x:Name="gd">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="43*"/>
                            <ColumnDefinition Width="114*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.ColumnSpan="2">
                            <GroupBox Header="图像链接">
                                <StackPanel Orientation="Horizontal" Margin="5 0">
                                    <TextBlock Text="输入图像" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0 0 0 1" Width="200" Margin="5 0"
                                     Style="{StaticResource LinkTextBox}"
                                     Text="{Binding InputImageLinkText}"
                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"/>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="1" Grid.ColumnSpan="2">
                            <GroupBox Header="参数设置">
                                <StackPanel>
                                    <!-- 直线1 -->
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="直线1:" VerticalAlignment="Center" Width="60"/>
                                        <ComboBox Width="200" Margin="5 0"
                                                  ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eLineSourceMode}}}"
                                                  SelectedItem="{Binding Line1SourceMode}"/>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding Line1SourceMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static vm:eLineSourceMode.链接直线}}">
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　链接:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line1LinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line1}"
                                                     mah:TextBoxHelper.Watermark="object"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding Line1SourceMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static vm:eLineSourceMode.两点构造}}">
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点1X:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line1P1XLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line1Point1X}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点1Y:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line1P1YLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line1Point1Y}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点2X:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line1P2XLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line1Point2X}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点2Y:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line1P2YLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line1Point2Y}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 直线2 -->
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="直线2:" VerticalAlignment="Center" Width="60"/>
                                        <ComboBox Width="200" Margin="5 0"
                                                  ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eLineSourceMode}}}"
                                                  SelectedItem="{Binding Line2SourceMode}"/>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding Line2SourceMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static vm:eLineSourceMode.链接直线}}">
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　链接:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line2LinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line2}"
                                                     mah:TextBoxHelper.Watermark="object"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding Line2SourceMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static vm:eLineSourceMode.两点构造}}">
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点1X:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line2P1XLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line2Point1X}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点1Y:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line2P1YLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line2Point1Y}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点2X:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line2P2XLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line2Point2X}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 0 5 0">
                                            <TextBlock Text="　点2Y:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding Line2P2YLinkText}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Line2Point2Y}"
                                                     mah:TextBoxHelper.Watermark="double"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 距离模式 -->
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="距离模式:" VerticalAlignment="Center" Width="60"/>
                                        <ComboBox Width="200" Margin="5 0"
                                                  ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eDistanceMode}}}"
                                                  SelectedItem="{Binding DistanceMode}"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="2" Grid.ColumnSpan="2" Grid.RowSpan="2">
                            <GroupBox Header="输出数据">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="距离:" VerticalAlignment="Center" Width="60"/>
                                        <TextBox Width="200" Margin="5 0" BorderThickness="0 0 0 1" Text="{Binding Distance}" IsReadOnly="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="显示设置">
                    <Grid x:Name="gd2">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Border Width="{Binding ElementName=gd2,Path=ActualWidth}">
                            <GroupBox Header="显示设置" Height="{Binding ElementName=gd2,Path=ActualHeight}" Grid.Row="1" VerticalAlignment="Top" Width="{Binding ElementName=dp,Path=ActualWidth}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <CheckBox Content="显示结果线" IsChecked="{Binding ShowResultLine}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <CheckBox Content="显示检测点" IsChecked="{Binding ShowResultPoint}"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost">
            </WinFormHost:WindowsFormsHost>

        </Grid>
        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" HorizontalAlignment="Right" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" HorizontalAlignment="Right" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确认" HorizontalAlignment="Right" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</vb:ModuleViewBase>
