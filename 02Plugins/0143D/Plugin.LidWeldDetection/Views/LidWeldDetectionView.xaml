<vb:ModuleViewBase x:Class="Plugin.LidWeldDetection.Views.LidWeldDetectionView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.LidWeldDetection.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.LidWeldDetection.ViewModels"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Height="720" Width="1050"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                    <vm:EnumDescConverter x:Key="EnumDescConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <!-- 主内容区：左侧参数 + 右侧图像 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>

                <!-- 基本参数 -->
                <TabItem Header="基本参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 图像链接 -->
                            <Border>
                                <GroupBox Header="图像链接">
                                    <StackPanel Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="输入图像" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Style="{StaticResource LinkTextBox}" Width="220" Margin="5 0"
                                                 BorderThickness="0 0 0 1" IsReadOnly="True"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"
                                                 mah:TextBoxHelper.Watermark="HImage"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 采样设置 -->
                            <Border Grid.Row="1">
                                <GroupBox Header="采样设置">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="X方向采样率:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding SampleRateX}"
                                                               Minimum="2" Maximum="2000" Interval="10"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="Y方向采样率:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding SampleRateY}"
                                                               Minimum="2" Maximum="2000" Interval="10"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="插值方法:" VerticalAlignment="Center" Width="90"/>
                                            <ComboBox Width="180" Margin="5 0"
                                                      ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eInterpolationMethod}}}"
                                                      SelectedItem="{Binding InterpolationMethod}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 高度换算设置 -->
                            <Border Grid.Row="2">
                                <GroupBox Header="高度换算">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="Z像素单位:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding ResolutionZ}"
                                                               Minimum="0.000000001" Maximum="999999999" Interval="0.001"
                                                               StringFormat="0.#########"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最小有效高度:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding MinValidHeight}"
                                                               Minimum="-999999999" Maximum="999999999" Interval="1"
                                                               StringFormat="0.######"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最大有效高度:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding MaxValidHeight}"
                                                               Minimum="-999999999" Maximum="999999999" Interval="100"
                                                               StringFormat="0.######"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 检测设置 -->
                            <Border Grid.Row="3">
                                <GroupBox Header="检测设置">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="缺陷类型:" VerticalAlignment="Center" Width="90"/>
                                            <ComboBox Width="180" Margin="5 0"
                                                      ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eDefectType}}}"
                                                      SelectedItem="{Binding DefectType}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- 凹陷阈值（凹 或 凹&凸时显示） -->
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DefectType}" Value="{x:Static vm:eDefectType.Concave}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DefectType}" Value="{x:Static vm:eDefectType.Both}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="凹陷阈值:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding ConcaveThreshold}"
                                                               Minimum="0.01" Maximum="999999" Interval="1"
                                                               StringFormat="0.##"/>
                                        </StackPanel>

                                        <!-- 凸起阈值（凸 或 凹&凸时显示） -->
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DefectType}" Value="{x:Static vm:eDefectType.Convex}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DefectType}" Value="{x:Static vm:eDefectType.Both}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="凸起阈值:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding ConvexThreshold}"
                                                               Minimum="0.001" Maximum="999999" Interval="0.1"
                                                               StringFormat="0.##"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最小缺陷面积:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding MinDefectArea}"
                                                               Minimum="0" Maximum="999999999" Interval="10"
                                                               StringFormat="0.##"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最大缺陷面积:" VerticalAlignment="Center" Width="90"/>
                                            <mah:NumericUpDown Width="180" Margin="5 0"
                                                               Value="{Binding MaxDefectArea}"
                                                               Minimum="0" Maximum="999999999" Interval="100"
                                                               StringFormat="0.##"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <CheckBox Content="显示工件轮廓" IsChecked="{Binding ShowWorkpieceContour}"
                                                      VerticalAlignment="Center" Width="120"/>
                                            <TextBlock Text="偏移(px):" VerticalAlignment="Center" Margin="8 0 0 0"/>
                                            <mah:NumericUpDown Width="95" Margin="5 0"
                                                               Value="{Binding ContourOffset}"
                                                               Minimum="-9999" Maximum="9999" Interval="1"
                                                               StringFormat="0.##"/>
                                        </StackPanel>
                                        <CheckBox Content="显示缺陷区域" IsChecked="{Binding ShowDefectRegion}" Margin="5"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 显示设置 -->
                            <Border Grid.Row="4">
                                <GroupBox Header="显示设置">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="当前显示:" VerticalAlignment="Center" Width="70"/>
                                            <TextBlock Text="{Binding DisplayMode, Converter={StaticResource EnumDescConverter}}"
                                                       VerticalAlignment="Center" Margin="5 0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- 结果输出 -->
                <TabItem Header="结果输出">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border>
                                <GroupBox Header="缺陷统计">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="是否有缺陷:" VerticalAlignment="Center" Width="90"/>
                                            <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding HasDefect}" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="缺陷数量:" VerticalAlignment="Center" Width="90"/>
                                            <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding DefectCount}" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="缺陷面积:" VerticalAlignment="Center" Width="90"/>
                                            <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding DefectArea, StringFormat=F2}" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最大凹陷深度:" VerticalAlignment="Center" Width="90"/>
                                            <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding MaxConcaveDepth, StringFormat=F4}" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="最大凸起高度:" VerticalAlignment="Center" Width="90"/>
                                            <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding MaxConvexHeight, StringFormat=F4}" IsReadOnly="True"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1"/>

            <!-- 右侧图像显示区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <WinFormHost:WindowsFormsHost Margin="5" x:Name="winFormHost"/>

                <!-- 显示切换按钮 -->
                <Border Grid.Row="1" Margin="5 2">
                    <UniformGrid Columns="4">
                        <Button Content="原始图像" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.Original}"/>
                        <Button Content="拟合结果" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.Fitted}"/>
                        <Button Content="差值结果" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.Difference}"/>
                        <Button Content="检测结果" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.Detection}"/>
                    </UniformGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/><Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确定" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
