<vb:ModuleViewBase x:Class="Plugin.VolumeMeasurement.Views.VolumeMeasurementView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.VolumeMeasurement.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.VolumeMeasurement.ViewModels"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Height="620"
                   Width="950"
                   Icon="/Plugin.VolumeMeasurement;component/Assets/Images/Tool/VolumeMeasurement.png"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                    <vm:EnumDescConverter x:Key="EnumDescConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="305"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>

                <TabItem Header="参数设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border>
                                <GroupBox Header="图像设置">
                                    <StackPanel Orientation="Horizontal" Margin="5 2">
                                        <TextBlock Text="输入图像" VerticalAlignment="Center" Width="85"/>
                                        <TextBox Style="{StaticResource LinkTextBox}"
                                                 Width="175"
                                                 BorderThickness="0 0 0 1"
                                                 IsReadOnly="True"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"
                                                 mah:TextBoxHelper.Watermark="HImage"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <Border Grid.Row="1">
                                <GroupBox Header="方式">
                                    <StackPanel Orientation="Horizontal" Margin="5 2">
                                        <TextBlock Text="计算方法:" VerticalAlignment="Center" Width="85"/>
                                        <ComboBox Width="175"
                                                  ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eVolumeCalcMode}}}"
                                                  SelectedItem="{Binding CalcMode}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <Border Grid.Row="2">
                                <GroupBox Header="构建参数">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="剔除高度(mm):" VerticalAlignment="Center" Width="85"/>
                                             <TextBox Style="{StaticResource LinkTextBox}"
                                                      Width="175"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding RemoveHeight.Text}"
                                                     IsReadOnly="{Binding RemoveHeight.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding RemoveHeight.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RemoveHeight}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="基准平面:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     Width="175"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding BasePlaneLinkText}"
                                                     IsReadOnly="True"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.BasePlaneLink}"
                                                     mah:TextBoxHelper.Watermark="空=Z0平面"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="测量区域:" VerticalAlignment="Center" Width="85"/>
                                            <ComboBox Width="175"
                                                      ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eMeasureRegionSource}}}"
                                                      SelectedItem="{Binding MeasureRegionSource}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2"
                                                    Visibility="{Binding MeasureRegionSource, ConverterParameter={x:Static vm:eMeasureRegionSource.LinkRegion}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <TextBlock Text="区域链接:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     Width="135"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding MeasureRegionLinkText}"
                                                     IsReadOnly="True"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasureRegionLink}"
                                                     mah:TextBoxHelper.Watermark="HRegion"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="X分辨率:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     Width="135"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding ResolutionX.Text}"
                                                     IsReadOnly="{Binding ResolutionX.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding ResolutionX.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.ResolutionX}"/>
                                            <TextBlock Text="mm/px" VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="Y分辨率:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     Width="135"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding ResolutionY.Text}"
                                                     IsReadOnly="{Binding ResolutionY.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding ResolutionY.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.ResolutionY}"/>
                                            <TextBlock Text="mm/px" VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="Z分辨率:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     Width="135"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding ResolutionZ.Text}"
                                                     IsReadOnly="{Binding ResolutionZ.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding ResolutionZ.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.ResolutionZ}"/>
                                            <TextBlock Text="mm/unit" VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <Border Grid.Row="3">
                                <GroupBox Header="输出数据">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 35 5 2">
                                            <TextBlock Text="体积:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Width="175"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding Volume, StringFormat={}{0:F6}}"
                                                     IsReadOnly="True"/>
                                            <TextBlock Text="{Binding VolumeUnit}" VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="有效点数:" VerticalAlignment="Center" Width="85"/>
                                            <TextBox Width="175"
                                                     BorderThickness="0 0 0 1"
                                                     Text="{Binding ValidPointCount}"
                                                     IsReadOnly="True"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="显示设置">
                    <Grid>
                        <Border>
                            <GroupBox Header="显示设置">
                                <StackPanel>
                                    <CheckBox Content="显示测量区域" IsChecked="{Binding ShowRegion}" Margin="5 2"/>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确定" Margin="10 0" Command="{Binding ConfirmCommand}" Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
