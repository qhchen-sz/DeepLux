<vb:ModuleViewBase x:Class="Plugin.HeightMeasurement.Views.HeightMeasurementView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.HeightMeasurement.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.HeightMeasurement.ViewModels"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Height="680" Width="980"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                    <vm:EnumDescConverter x:Key="EnumDescConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>

                <!-- 基本参数 -->
                <TabItem Header="基本参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 图像设置 -->
                            <Border>
                                <GroupBox Header="图像设置">
                                    <StackPanel Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="输入图像" VerticalAlignment="Center" Width="60"/>
                                        <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0"
                                                 BorderThickness="0 0 0 1" IsReadOnly="True"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"
                                                 mah:TextBoxHelper.Watermark="HImage"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- ROI信息1(基准区域) -->
                            <Border Grid.Row="1">
                                <GroupBox Header="ROI信息1(基准区域)">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <RadioButton Content="手动绘制" Margin="5 0"
                                                IsChecked="{Binding RefRoiSource, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRefRoiSource.Manual}}"/>
                                            <RadioButton Content="链接区域" Margin="5 0"
                                                IsChecked="{Binding RefRoiSource, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRefRoiSource.LinkRegion}}"/>
                                            <RadioButton Content="链接基准" Margin="5 0"
                                                IsChecked="{Binding RefRoiSource, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRefRoiSource.LinkBase}}"/>
                                        </StackPanel>

                                        <!-- 手动绘制时显示参数 -->
                                        <StackPanel Visibility="{Binding RefRoiSource, ConverterParameter={x:Static vm:eRefRoiSource.Manual}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="长边l1:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiLength1.Text}"
                                                         IsReadOnly="{Binding RefRoiLength1.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding RefRoiLength1.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiLength1}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="短边l2:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiLength2.Text}"
                                                         IsReadOnly="{Binding RefRoiLength2.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding RefRoiLength2.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiLength2}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="中心X:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiCenterX.Text}"
                                                         IsReadOnly="{Binding RefRoiCenterX.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding RefRoiCenterX.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiCenterX}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="中心Y:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiCenterY.Text}"
                                                         IsReadOnly="{Binding RefRoiCenterY.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding RefRoiCenterY.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiCenterY}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="角度(°):" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiAngel.Text}"
                                                         IsReadOnly="{Binding RefRoiAngel.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding RefRoiAngel.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiAngel}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 链接区域时显示ROI链接 -->
                                        <StackPanel Visibility="{Binding RefRoiSource, ConverterParameter={x:Static vm:eRefRoiSource.LinkRegion}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="ROI链接:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefRoiLinkText}" IsReadOnly="True"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefRoiLink}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 链接基准时显示基准平面图像链接 -->
                                        <StackPanel Visibility="{Binding RefRoiSource, ConverterParameter={x:Static vm:eRefRoiSource.LinkBase}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="基准平面图像:" VerticalAlignment="Center" Width="75"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="185" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding RefBasePlaneLinkText}" IsReadOnly="True"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.RefBasePlaneLink}"
                                                         mah:TextBoxHelper.Watermark="HImage"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="当不链接区域,则默认基准为0点" Margin="5 2" Foreground="Gray" FontSize="12"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- ROI信息2(测量区域) -->
                            <Border Grid.Row="2">
                                <GroupBox Header="ROI信息2(测量区域)">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <RadioButton Content="手动绘制" Margin="5 0"
                                                IsChecked="{Binding MeasRoiSource, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eMeasRoiSource.Manual}}"/>
                                            <RadioButton Content="链接区域" Margin="5 0"
                                                IsChecked="{Binding MeasRoiSource, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eMeasRoiSource.LinkRegion}}"/>
                                        </StackPanel>

                                        <!-- 手动绘制时显示参数 -->
                                        <StackPanel Visibility="{Binding MeasRoiSource, ConverterParameter={x:Static vm:eMeasRoiSource.Manual}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="长边l1:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiLength1.Text}"
                                                         IsReadOnly="{Binding MeasRoiLength1.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding MeasRoiLength1.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiLength1}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="短边l2:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiLength2.Text}"
                                                         IsReadOnly="{Binding MeasRoiLength2.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding MeasRoiLength2.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiLength2}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="中心X:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiCenterX.Text}"
                                                         IsReadOnly="{Binding MeasRoiCenterX.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding MeasRoiCenterX.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiCenterX}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="中心Y:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiCenterY.Text}"
                                                         IsReadOnly="{Binding MeasRoiCenterY.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding MeasRoiCenterY.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiCenterY}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="角度(°):" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiAngel.Text}"
                                                         IsReadOnly="{Binding MeasRoiAngel.IsReadOnly}"
                                                         mah:TextBoxHelper.Value="{Binding MeasRoiAngel.Value}"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiAngel}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 链接区域时显示ROI链接 -->
                                        <StackPanel Visibility="{Binding MeasRoiSource, ConverterParameter={x:Static vm:eMeasRoiSource.LinkRegion}, Converter={StaticResource EnumToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                                <TextBlock Text="ROI链接:" VerticalAlignment="Center" Width="60"/>
                                                <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                         Text="{Binding MeasRoiLinkText}" IsReadOnly="True"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MeasRoiLink}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- 测量设置 -->
                <TabItem Header="测量设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 测量结果 -->
                            <Border>
                                <GroupBox Header="测量结果">
                                    <StackPanel Orientation="Horizontal" Margin="5 2">
                                        <TextBlock Text="断差:" VerticalAlignment="Center" Width="60"/>
                                        <TextBox Width="200" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding HeightDifference, StringFormat={}{0:F3}}" IsReadOnly="True"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 测量方法 -->
                            <Border Grid.Row="1">
                                <GroupBox Header="测量方法">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="模式:" VerticalAlignment="Center" Width="60"/>
                                            <ComboBox Width="200" Margin="5 0"
                                                      ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eMeasureMode}}}"
                                                      SelectedItem="{Binding MeasureMode}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="筛选:" VerticalAlignment="Center" Width="60"/>
                                            <ComboBox Width="200" Margin="5 0"
                                                      ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eFilterMode}}}"
                                                      SelectedItem="{Binding FilterMode}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <CheckBox Content="将基准区域拟合平面,求点到面的距离"
                                                  IsChecked="{Binding FitPlaneForRef}" Margin="5 2"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <!-- 筛选规则 -->
                            <Border Grid.Row="2">
                                <GroupBox Header="筛选规则">
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FilterMode}" Value="{x:Static vm:eFilterMode.All}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="m:" VerticalAlignment="Center" Width="30"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding FilterM.Text}"
                                                     IsReadOnly="{Binding FilterM.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding FilterM.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.FilterM}"/>
                                            <CheckBox Content="百分比" IsChecked="{Binding FilterMIsPercent}" Margin="10 0 0 0"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5 2">
                                            <TextBlock Text="n:" VerticalAlignment="Center" Width="30"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"
                                                     Text="{Binding FilterN.Text}"
                                                     IsReadOnly="{Binding FilterN.IsReadOnly}"
                                                     mah:TextBoxHelper.Value="{Binding FilterN.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.FilterN}"/>
                                            <CheckBox Content="百分比" IsChecked="{Binding FilterNIsPercent}" Margin="10 0 0 0"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- 其他设置 -->
                <TabItem Header="其他设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border>
                                <GroupBox Header="显示设置">
                                    <StackPanel>
                                        <CheckBox Content="显示检测区域" IsChecked="{Binding ShowRegion}" Margin="5 2"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>

                            <Border Grid.Row="1">
                                <GroupBox Header="其他设置">
                                    <StackPanel Orientation="Horizontal" Margin="5 2">
                                        <TextBlock Text="重采样系数:" VerticalAlignment="Center" Width="70"/>
                                        <mah:NumericUpDown Width="150" Margin="5 0"
                                                           Value="{Binding ResampleFactor}"
                                                           Minimum="1" Maximum="10" Interval="1"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确定" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
