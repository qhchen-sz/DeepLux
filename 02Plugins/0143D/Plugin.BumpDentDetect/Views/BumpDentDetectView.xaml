<vb:ModuleViewBase x:Class="Plugin.BumpDentDetect.Views.BumpDentDetectView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.BumpDentDetect.ViewModels"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Height="680" Width="980"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                    <vm:EnumDescConverter x:Key="EnumDescConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>

                <TabItem Header="参数设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <GroupBox Header="图像链接">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="输入图像:" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Style="{StaticResource LinkTextBox}" Width="220" Margin="5 0"
                                                 BorderThickness="0 0 0 1" IsReadOnly="True"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"
                                                 mah:TextBoxHelper.Watermark="HImage"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="顶帽参数">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="Z分辨率:" VerticalAlignment="Center" Width="90"/>
                                        <mah:NumericUpDown Width="180" Margin="5 0"
                                                           Value="{Binding ResolutionZ}"
                                                           Minimum="0.000001" Maximum="999999999" Interval="0.1"
                                                           StringFormat="0.######"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="核大小(像素):" VerticalAlignment="Center" Width="90"/>
                                        <mah:NumericUpDown Width="180" Margin="5 0"
                                                           Value="{Binding KernelSize}"
                                                           Minimum="3" Maximum="999" Interval="2"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="检测类型:" VerticalAlignment="Center" Width="90"/>
                                        <ComboBox Width="180" Margin="5 0"
                                                  ItemsSource="{Binding Source={enum:EnumBindingSource {x:Type vm:eDefectType}}}"
                                                  SelectedItem="{Binding DefectType}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="高度阈值:" VerticalAlignment="Center" Width="90"/>
                                        <mah:NumericUpDown Width="180" Margin="5 0"
                                                           Value="{Binding Threshold}"
                                                           Minimum="0.001" Maximum="999999" Interval="0.05"
                                                           StringFormat="0.######"/>
                                    </StackPanel>
                                    <CheckBox Content="显示检测区域" IsChecked="{Binding ShowRegion}" Margin="5"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="结果输出">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <GroupBox Header="凸起统计">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="凸起数量:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding BumpCount}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="凸起面积:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding BumpArea, StringFormat=F2}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="最大凸起高度:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding MaxBumpHeight, StringFormat=F4}" IsReadOnly="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="凹坑统计">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="凹坑数量:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding DentCount}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="凹坑面积:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding DentArea, StringFormat=F2}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="最大凹坑深度:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding MaxDentDepth, StringFormat=F4}" IsReadOnly="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <WinFormHost:WindowsFormsHost Margin="5" x:Name="winFormHost"/>
                <Border Grid.Row="1" Margin="5 2">
                    <UniformGrid Columns="3">
                        <Button Content="原始图像" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.Original}"/>
                        <Button Content="凸起检测" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.BumpResult}"/>
                        <Button Content="凹坑检测" Margin="2"
                                Command="{Binding SwitchDisplayCommand}"
                                CommandParameter="{x:Static vm:eDisplayMode.DentResult}"/>
                    </UniformGrid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/><Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确定" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
