<vb:ModuleViewBase x:Class="Plugin.CropImage.Views.CropImageView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                   xmlns:helper="clr-namespace:HV.Common.Helper;assembly=HV"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   xmlns:vm="clr-namespace:Plugin.CropImage.ViewModels"
                   xmlns:local="clr-namespace:Plugin.CropImage.Views"
                   Icon="/Plugin.CropImage;component/Assets/Images/Tool/CropImage.png"
                   Height="680" Width="980"
                   >
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="基本参数">
                    <Grid x:Name="gd">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border>
                            <GroupBox Header="图像设置">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="输入图像:" HorizontalAlignment="Center" VerticalAlignment="Center" Width="60"/>
                                        <TextBox HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0 0 0 1" Width="200" Margin="5 0" IsReadOnly="True"
                                                 Style="{StaticResource LinkTextBox}"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsOutputCropImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="10" Content="输出ROI裁剪图像"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="1">
                            <GroupBox Header="ROI模式">
                                <Grid>
                                    <Border VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10 0">
                                        <StackPanel Orientation="Horizontal" Margin="5 10">
                                            <RadioButton Content="手动输入" Margin="5 0"
                                                         IsChecked="{Binding SearchRegionSource,Converter={StaticResource EnumConverter},ConverterParameter={x:Static vm:eROISource.手动输入}}"/>
                                            <RadioButton Content="链接数组" Margin="5 0"
                                                         IsChecked="{Binding SearchRegionSource,Converter={StaticResource EnumConverter},ConverterParameter={x:Static vm:eROISource.链接数组}}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="2">
                            <GroupBox Header="ROI信息">
                                <Grid>
                                    <Grid Visibility="{Binding SearchRegionSource,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static vm:eROISource.手动输入}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Height="40"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                            <Button Command="{Binding AddDataCommand}" Margin="5">添加</Button>
                                            <Button Command="{Binding DelDataCommand}" Margin="5">删除</Button>
                                        </StackPanel>
                                        <DataGrid Grid.Row="1" Margin="5" x:Name="dg"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  FontSize="12"
                                                  GridLinesVisibility="All"
                                                  HeadersVisibility="Column"
                                                  ItemsSource="{Binding DataList}"
                                                  SelectedItem="{Binding SelectedData}"
                                                  SelectedIndex="{Binding SelectedIndex}"
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="50" Binding="{Binding NO}" CanUserSort="True" Header="No." IsReadOnly="True"/>
                                                <DataGridTextColumn Width="*" Binding="{Binding X,Mode=TwoWay,UpdateSourceTrigger=LostFocus}" CanUserSort="False" Header="X" IsReadOnly="False"/>
                                                <DataGridTextColumn Width="*" Binding="{Binding Y,Mode=TwoWay,UpdateSourceTrigger=LostFocus}" CanUserSort="False" Header="Y" IsReadOnly="False"/>
                                                <DataGridTextColumn Width="*" Binding="{Binding L1,Mode=TwoWay,UpdateSourceTrigger=LostFocus}" CanUserSort="False" Header="L1" IsReadOnly="False"/>
                                                <DataGridTextColumn Width="*" Binding="{Binding L2,Mode=TwoWay,UpdateSourceTrigger=LostFocus}" CanUserSort="False" Header="L2" IsReadOnly="False"/>
                                                <DataGridTextColumn Width="*" Binding="{Binding Deg,Mode=TwoWay,UpdateSourceTrigger=LostFocus}" CanUserSort="False" Header="角度" IsReadOnly="False"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                    <StackPanel Visibility="{Binding SearchRegionSource,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static vm:eROISource.链接数组}}">
                                        <StackPanel Orientation="Horizontal" Margin="20 10">
                                            <TextBlock Text="中心X:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200"
                                                     Text="{Binding CenterXLink.Text,UpdateSourceTrigger=PropertyChanged}"
                                                     mah:TextBoxHelper.Value="{Binding CenterXLink.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.CenterXLink}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="20 10">
                                            <TextBlock Text="中心Y:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200"
                                                     Text="{Binding CenterYLink.Text,UpdateSourceTrigger=PropertyChanged}"
                                                     mah:TextBoxHelper.Value="{Binding CenterYLink.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.CenterYLink}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="20 10">
                                            <TextBlock Text="长度1:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200"
                                                     Text="{Binding Length1Link.Text,UpdateSourceTrigger=PropertyChanged}"
                                                     mah:TextBoxHelper.Value="{Binding Length1Link.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Length1Link}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="20 10">
                                            <TextBlock Text="长度2:" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200"
                                                     Text="{Binding Length2Link.Text,UpdateSourceTrigger=PropertyChanged}"
                                                     mah:TextBoxHelper.Value="{Binding Length2Link.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.Length2Link}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="20 10">
                                            <TextBlock Text="角度(°):" VerticalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" Width="200"
                                                     Text="{Binding AngleLink.Text,UpdateSourceTrigger=PropertyChanged}"
                                                     mah:TextBoxHelper.Value="{Binding AngleLink.Value}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.AngleLink}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="显示设置">
                    <Grid x:Name="gd2">
                        <GroupBox Header="显示设置">
                            <StackPanel>
                                <CheckBox Content="流程结束时显示结果图像" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 10 0 0"
                                          IsChecked="{Binding ShowResultRoi}"/>
                                <StackPanel Orientation="Horizontal" Margin="10">
                                    <TextBlock Text="显示窗体" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ComboBox HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0 0 0 1" Width="200" Margin="5 0"
                                              SelectedIndex="{Binding DispViewID}" ItemsSource="{Binding CanvasList}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost">
            </WinFormHost:WindowsFormsHost>
        </Grid>
        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:" />
                        <Run Text="{Binding ModuleParam.ElapsedTime}" />
                        <Run Text="ms" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:" />
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" HorizontalAlignment="Right" Margin="10 0" Command="{Binding ExecuteCommand}" />
                    <Button x:Name="btnCancel" Content="取消" HorizontalAlignment="Right" Margin="10 0" Click="btnCancel_Click" />
                    <Button x:Name="btnConfirm" Content="确认" HorizontalAlignment="Right" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
