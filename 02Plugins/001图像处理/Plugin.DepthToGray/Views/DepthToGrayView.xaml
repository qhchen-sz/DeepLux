<vb:ModuleViewBase x:Class="Plugin.DepthToGray.Views.DepthToGrayView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.DepthToGray.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                   xmlns:helper="clr-namespace:HV.Common.Helper;assembly=HV"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:vm="clr-namespace:Plugin.DepthToGray.ViewModels"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Icon="/Plugin.DepthToGray;component/Assets/Images/Tool/DepthToGray.png"
                   Height="680" Width="980"
                   >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="基本参数">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0">
                            <GroupBox Header="输入图像">
                                <StackPanel HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="10">
                                        <TextBlock Text="深度图:" VerticalAlignment="Center" Width="60"/>
                                        <TextBox Text="{Binding InputImageLink.Text,UpdateSourceTrigger=PropertyChanged}"
                                                 mah:TextBoxHelper.Value="{Binding InputImageLink.Value}"
                                                 Style="{StaticResource LinkTextBox}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"
                                                 mah:TextBoxHelper.Watermark="HImage"
                                                 VerticalAlignment="Center" HorizontalAlignment="Center" Width="150" Margin="5 0"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <GroupBox Header="参数列表" Grid.Row="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="结果图像类型:" VerticalAlignment="Center" Width="100"/>
                                    <ComboBox Width="150" VerticalAlignment="Center" Margin="5 0"
                                              SelectedItem="{Binding ResultImageType}"
                                              ItemsSource="{Binding ImageTypeList}"/>
                                </StackPanel>
                                <CheckBox Content="限制值" Margin="10 5" IsChecked="{Binding IsLimitValue}"/>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="滤掉无效值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding FilterInvalidValue.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding FilterInvalidValue.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.FilterInvalidValue}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="减去高度值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding SubtractHeight.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding SubtractHeight.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.SubtractHeight}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="深度上最小Z值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding MinZValue.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding MinZValue.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MinZValue}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"
                                             IsEnabled="{Binding IsLimitValue}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="深度上最大Z值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding MaxZValue.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding MaxZValue.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MaxZValue}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"
                                             IsEnabled="{Binding IsLimitValue}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="对应最小灰度值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding MinGrayValue.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding MinGrayValue.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MinGrayValue}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="对应最大灰度值:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding MaxGrayValue.Text,UpdateSourceTrigger=PropertyChanged}"
                                             mah:TextBoxHelper.Value="{Binding MaxGrayValue.Value}"
                                             Style="{StaticResource LinkTextBox}"
                                             mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                             mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.MaxGrayValue}"
                                             mah:TextBoxHelper.Watermark="double"
                                             VerticalAlignment="Center" Width="150" Margin="5 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="10 5">
                                    <TextBlock Text="Z分辨率:" VerticalAlignment="Center" Width="100"/>
                                    <mah:NumericUpDown Width="150" Margin="5 0"
                                                       Value="{Binding ResolutionZ}"
                                                       Minimum="0.00000001" Maximum="999999999" Interval="0.0001"
                                                       StringFormat="0.####"
                                                       VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>
                <TabItem Header="高度分布">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="高度值分布趋势" Foreground="#FFCCCCCC" 
                                   FontSize="14" FontWeight="Bold" Margin="10,5" HorizontalAlignment="Center"/>
                        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#FF4D4D4D" CornerRadius="5" Margin="2">
                            <Grid Background="#FF2D2D30">
                                <!-- Y轴最大值标签 -->
                                <TextBlock Text="{Binding HistoMaxCount}" Foreground="#FF888888" 
                                           FontSize="9" Margin="2,2,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                <!-- Y轴标签 -->
                                <TextBlock Text="个数" Foreground="#FF888888" FontSize="9"
                                           Margin="2,0,0,20" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <Canvas x:Name="histoCanvas" Margin="28,5,5,20" Width="330" Height="170" ClipToBounds="True">
                                    <!-- Y轴（位于平均值处） -->
                                    <Line X1="{Binding HistoCenterX}" Y1="0" X2="{Binding HistoCenterX}" Y2="170" Stroke="#FF888888" StrokeThickness="1"/>
                                    <!-- X轴 -->
                                    <Line X1="0" Y1="170" X2="330" Y2="170" Stroke="#FF888888" StrokeThickness="1"/>
                                    <!-- 折线 -->
                                    <Polyline Points="{Binding HistoPoints}" Stroke="#FF4A90D9" StrokeThickness="1.5" Fill="Transparent"/>
                                    <!-- 填充区域 -->
                                    <Polygon Points="{Binding HistoFillPoints}" Fill="#1A4A90D9" Stroke="Transparent"/>
                                </Canvas>
                                <!-- X轴最小值标签 -->
                                <TextBlock Text="{Binding HistoMin,StringFormat=F2}" Foreground="#FF888888" FontSize="9"
                                           Margin="28,0,0,2" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                <!-- X轴平均值标签（位于中间） -->
                                <TextBlock Text="{Binding HistoMean,StringFormat=F2}" Foreground="#FF4A90D9" FontSize="9"
                                           Margin="0,0,0,2" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontWeight="Bold"/>
                                <!-- X轴最大值标签 -->
                                <TextBlock Text="{Binding HistoMax,StringFormat=F2}" Foreground="#FF888888" FontSize="9"
                                           Margin="0,0,5,2" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,2">
                            <TextBlock>
                                <Run Text="最小值:"/><Run Text="{Binding HistoMin,StringFormat=F4}"/>
                            </TextBlock>
                            <TextBlock Margin="10,0,0,0">
                                <Run Text="最大值:"/><Run Text="{Binding HistoMax,StringFormat=F4}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5,2">
                            <TextBlock>
                                <Run Text="平均值:"/><Run Text="{Binding HistoMean,StringFormat=F4}"/>
                            </TextBlock>
                            <TextBlock Margin="10,0,0,0">
                                <Run Text="标准差:"/><Run Text="{Binding HistoStdDev,StringFormat=F4}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#FF4D4D4D"/>
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="#FF4D4D4D" CornerRadius="5">
                <Grid Background="#FF3E3E42">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid x:Name="mWindowGrid" Background="#FF3E3E42" Margin="2" ClipToBounds="True">
                        <WindowsFormsHost x:Name="winFormHost" Margin="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/><Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确认" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
