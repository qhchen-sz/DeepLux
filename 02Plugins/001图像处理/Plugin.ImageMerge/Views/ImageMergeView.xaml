<vb:ModuleViewBase x:Class="Plugin.ImageMerge.Views.ImageMergeView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   Icon="/Plugin.ImageMerge;component/Assets/Images/Tool/ImageMerge.png"
                   Height="680"
                   Width="980"
                   mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>

                <TabItem Header="基本参数">
                    <GroupBox Header="图像设置" Margin="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding AddDataCommand}" Margin="6 0">添加</Button>
                                <Button Command="{Binding DelDataCommand}" Margin="6 0">删除</Button>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      Margin="6"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      ItemsSource="{Binding DataList}"
                                      SelectedItem="{Binding SelectedData}"
                                      SelectedIndex="{Binding SelectedIndex}"
                                      RowHeaderWidth="22"
                                      SelectionUnit="FullRow"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="序号" Width="40" Binding="{Binding Index}" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="待合并图像" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding InputImageLink.Text,UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="True"
                                                         BorderThickness="0 0 0 0"
                                                         Style="{StaticResource LinkTextBox}"
                                                         Background="Transparent"
                                                         Width="Auto"
                                                         mah:TextBoxHelper.Value="{Binding InputImageLink.Value}"
                                                         VerticalAlignment="Center"
                                                         mah:TextBoxHelper.LinkButtonCommand="{Binding DataContext.LinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         mah:TextBoxHelper.LinkButtonCommandParameter="{Binding Index}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="60" Binding="{Binding Row1,Mode=TwoWay,UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="row1"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                    <DataGridTextColumn Width="60" Binding="{Binding Col1,Mode=TwoWay,UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="col1"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>
                </TabItem>

                <TabItem Header="参数说明">
                    <Grid Margin="8 6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="按偏移坐标直接拼接图像" FontWeight="Bold" Margin="0 0 0 8" Foreground="White"/>
                        <Border Grid.Row="1" BorderBrush="#FF7AA7D9" BorderThickness="1" Background="#FF5E97CD">
                            <Canvas Width="320" Height="270">
                                <Rectangle Canvas.Left="32" Canvas.Top="36" Width="100" Height="80" Fill="#FFB3B3B3" Stroke="#FF8C8C8C"/>
                                <TextBlock Canvas.Left="36" Canvas.Top="40" Text="图1 (0,0)" FontSize="12"/>
                                <Rectangle Canvas.Left="132" Canvas.Top="116" Width="100" Height="80" Fill="#FF999999" Stroke="#FF8C8C8C"/>
                                <TextBlock Canvas.Left="136" Canvas.Top="120" Text="图2 (100,50)" FontSize="12"/>
                                <Ellipse Canvas.Left="26" Canvas.Top="32" Width="8" Height="8" Fill="#FFFF7A00"/>
                                <Line X1="30" Y1="36" X2="30" Y2="4" Stroke="#FFFF7A00" StrokeThickness="1.5"/>
                                <Line X1="30" Y1="36" X2="2" Y2="36" Stroke="#FFFF7A00" StrokeThickness="1.5"/>
                                <Polygon Fill="#FFFF7A00" Points="30,2 27,8 33,8"/>
                                <Polygon Fill="#FFFF7A00" Points="0,36 6,33 6,39"/>
                            </Canvas>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Grid.Column="2" Margin="5" x:Name="winFormHost"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button x:Name="btnConfirm" Content="确定" Margin="10 0" Command="{Binding ConfirmCommand}" Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                    <Button x:Name="btnCancel" Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
