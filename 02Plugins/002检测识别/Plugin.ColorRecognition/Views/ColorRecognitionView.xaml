<vb:ModuleViewBase x:Class="Plugin.ColorRecognition.Views.ColorRecognitionView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"      
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                   xmlns:helper="clr-namespace:HV.Common.Helper;assembly=HV"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   xmlns:hw="clr-namespace:VM.Halcon;assembly=VM.Halcon"
                   xmlns:vm="clr-namespace:Plugin.ColorRecognition.ViewModels"
                   xmlns:local="clr-namespace:Plugin.ColorRecognition.Views"
                   Icon="/Plugin.ColorRecognition;component/Assets/Images/Tool/ColorRecognition.png"
                   Height="680" Width="980"
                   >
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                    <cvt:InvertBool2VisibilityConverter x:Key="InvertBool2VisibilityConverter"/>
                    <cvt:Bool2VisibilityConverter x:Key="Bool2VisibilityConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="基本参数">
                    <Grid x:Name="gd">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="103*"/>
                            <ColumnDefinition Width="19*"/>
                            <ColumnDefinition Width="222*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.ColumnSpan="3" >
                            <GroupBox Header="图像链接">
                                <StackPanel Orientation="Horizontal" Margin="5 0">
                                    <TextBlock Text="输入图像" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="0 0 0 1" Width="200" Margin="5 0" IsReadOnly="True"
                                     Style="{StaticResource LinkTextBox}"
                                     Text="{Binding InputImageLinkText}"
                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"/>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="1" Grid.ColumnSpan="3">
                            <GroupBox Header="搜索区域信息">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Border BorderThickness="0 0 0 1" BorderBrush="Gray" Margin="10 0">
                                        <StackPanel Orientation="Horizontal" Margin="5 10" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <RadioButton Content="矩形1" Margin="5 0" 
                                                 IsChecked="{Binding SearchRegionSource,Converter={StaticResource EnumConverter},ConverterParameter={x:Static enum:eSearchRegion.矩形1}}"/>
                                         
                                            <RadioButton Content="链接区域" Margin="5 0" 
                                                 IsChecked="{Binding SearchRegionSource,Converter={StaticResource EnumConverter},ConverterParameter={x:Static enum:eSearchRegion.链接区域}}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Row="1" Visibility="{Binding SearchRegionSource,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static enum:eSearchRegion.矩形1}}">

                                        <StackPanel Orientation="Horizontal" Margin="30 10">
                                            <TextBlock Text="左上X:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}"
                                                     mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.UpperLeftX}"
                                                     mah:TextBoxHelper.Watermark="double"
                                                     Width="200" Text="{Binding Rectangle1SearchRegion.Col1}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="30 10">
                                            <TextBlock Text="左上Y:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" 
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.UpperLeftY}"
                                                     mah:TextBoxHelper.Watermark="double"
                                                     Width="200" Text="{Binding Rectangle1SearchRegion.Row1}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="30 10">
                                            <TextBlock Text="右下X:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" 
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.LowRightX}"
                                                     mah:TextBoxHelper.Watermark="double"
                                                     Width="200" Text="{Binding Rectangle1SearchRegion.Col2}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="30 10">
                                            <TextBlock Text="右下Y:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="60"/>
                                            <TextBox Style="{StaticResource LinkTextBox}" 
                                                     mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.LowRightY}"
                                                     mah:TextBoxHelper.Watermark="double"
                                                     Width="200" Text="{Binding Rectangle1SearchRegion.Row2}"/>
                                        </StackPanel>


                                    </StackPanel>



                                </Grid>
                            </GroupBox>
                        </Border>

                    </Grid>

                </TabItem>
                <TabItem Header="颜色学习设置">
                    <Grid x:Name="gd1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="87*"/>
                            <ColumnDefinition Width="85*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="240"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 颜色学习设置 -->
                        <Border Width="{Binding ElementName=gd1,Path=ActualWidth}" Height="auto" Grid.ColumnSpan="2">
                            <GroupBox Header="颜色学习" Width="{Binding ElementName=gd1,Path=ActualWidth}">
                                <Grid>
                                    <!-- 非学习状态 -->
                                    <Grid Visibility="{Binding IsLearning, Converter={StaticResource InvertBool2VisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 预览窗口 -->
                                        <Border BorderBrush="Gray" BorderThickness="1" Margin="5" 
                                                Background="Black" CornerRadius="3">
                                            <Grid>
                                                <!-- 预览图像显示区域 - 固定240x200大小 -->
                                                <WinFormHost:WindowsFormsHost Margin="0" x:Name="previewHost" 
                                                                             Height="195" Width="228">
                                                    <!-- Halcon 窗口控件会通过代码绑定 -->
                                                </WinFormHost:WindowsFormsHost>

                                                <!-- 没有预览图像时的提示 -->
                                                <Border Background="#CC000000" 
                                                        Visibility="{Binding HasPreviewImage, Converter={StaticResource InvertBool2VisibilityConverter}}">
                                                    <TextBlock Text="学习后显示预览" 
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"
                                                               Foreground="White"
                                                               FontSize="12"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="0 10">
                                            <TextBlock Text="颜色学习预览" FontWeight="Bold" Margin="10 0 0 10"/>
                                            <TextBlock Text="{Binding LearningStatusText}" 
                                                       Margin="20 0 0 20" 
                                                       Foreground="{Binding LearningStatusColor}"/>
                                            <Button Content="开始学习" Command="{Binding OperateCommand}" 
                                                    CommandParameter="{x:Static vm:eOperateCommand.StartLearn}"
                                                    Margin="20 10 0 0" Width="75"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 学习状态 -->
                                    <Grid Visibility="{Binding IsLearning, Converter={StaticResource Bool2VisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 学习时的提示区域 -->
                                        <Border BorderBrush="Orange" BorderThickness="2" Margin="5" 
                                                Background="Black" CornerRadius="3">
                                            <Grid>
                                                <TextBlock Text="请在主窗口绘制学习区域" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Foreground="Orange"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Margin="10"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="0 10">
                                            <TextBlock Text="正在学习颜色" 
                                                       Margin="0 0 0 20" 
                                                       Foreground="OrangeRed"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="请在右侧主图像窗口绘制学习区域" 
                                                       Margin="0 0 0 10"/>
                                            <Button Content="完成学习" Margin="20 10 0 0" Command="{Binding OperateCommand}" 
                                                    CommandParameter="{x:Static vm:eOperateCommand.EndLearn}"
                                                    ToolTip="完成颜色学习，生成颜色阈值"/>
                                            <Button Content="取消学习" Margin="20 10 0 0" Command="{Binding OperateCommand}" 
                                                    CommandParameter="{x:Static vm:eOperateCommand.Cancel}"
                                                    ToolTip="取消当前学习过程"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </GroupBox>
                        </Border>

                        <Border Width="{Binding ElementName=gd,Path=ActualWidth}" Grid.Row="1" Grid.ColumnSpan="2">
                            <GroupBox Header="颜色识别参数" Height="{Binding ElementName=gd1,Path=ActualHeight}" 
                                      Grid.Row="1" VerticalAlignment="Top" Width="{Binding ElementName=gd1,Path=ActualWidth}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="10 8">
                                        <TextBlock Text="最小分数(0-1):" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90"/>
                                        <mah:NumericUpDown Width="200" BorderThickness="0 0 0 1" 
                                                          Value="{Binding MinScore}" 
                                                          Interval="0.7"
                                                          Minimum="0" Maximum="1"
                                                          ToolTip="颜色区域面积与搜索区域面积的最小比值"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="10 8">
                                        <TextBlock Text="是否已学习:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90"/>
                                        <CheckBox IsChecked="{Binding IsTrained}"
                                                  IsEnabled="False" 
                                                  Content="{Binding IsTrained, Converter={StaticResource Bool2VisibilityConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="10 8" Visibility="Collapsed">
                                        <TextBlock Text="颜色空间:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90"/>
                                        <ComboBox Width="150" BorderThickness="0 0 0 1" Height="25" 
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="HSV" IsSelected="True"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="10 8">
                                        <TextBlock Text="容差设置:" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90"/>
                                        <TextBlock Text="H:15° S:30 V:40" VerticalAlignment="Center" Margin="10 0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="10 10 0 0">
                                        <TextBlock Text="当前分数:" VerticalAlignment="Center" Width="70"/>
                                        <TextBlock Text="{Binding ScoreValue, StringFormat=F3}" 
                                                   VerticalAlignment="Center" Margin="5 0"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="数据结果">
                    <Grid x:Name="gd2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <Border DockPanel.Dock="Top" Width="{Binding ElementName=gd2,Path=ActualWidth}">
                            <GroupBox Header="识别结果" Width="{Binding ElementName=gd2,Path=ActualWidth}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="AUTO"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="检测状态:" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding MathCoord.Status}" 
                                                   VerticalAlignment="Center" Margin="10 0"
                                                   Foreground="{Binding MathCoord.Status, Converter={StaticResource StatusConverter}}"/>
                                    </StackPanel>
                                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" x:Name="dg"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ItemsSource="{Binding MathTemplateModels}" 
                                                  SelectedItem="{Binding SelectedMathTemplate}"
                                                  FontSize="12" 
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="True" CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="索引" IsReadOnly="True" Width="auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ID}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Score" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Score, StringFormat=F3}" HorizontalAlignment="Left"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="X" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding X, StringFormat=F1}" HorizontalAlignment="Left"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Y" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Y, StringFormat=F1}" HorizontalAlignment="Left"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="状态" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Status}" HorizontalAlignment="Left">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="Green"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="False">
                                                                            <Setter Property="Foreground" Value="Red"/>
                                                                            <Setter Property="Text" Value="NG"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="True">
                                                                            <Setter Property="Text" Value="OK"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>
                        </Border>
                        <Border Width="{Binding ElementName=gd2,Path=ActualWidth}" Grid.Row="2">
                            <GroupBox Header="显示设置" Height="{Binding ElementName=gd2,Path=ActualHeight}" Grid.Row="1" VerticalAlignment="Top" 
                                      Width="{Binding ElementName=gd2,Path=ActualWidth}">
                                <StackPanel>
                                    <CheckBox Content="显示搜索区域" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 10 0 0" 
                                              IsChecked="{Binding ShowSearchRegion}"
                                              ToolTip="是否显示搜索区域"/>
                                    <CheckBox Content="显示结果轮廓" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10 10 0 0" 
                                              IsChecked="{Binding ShowResultContour}"
                                              ToolTip="是否显示颜色检测结果区域"/>
                                   
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost">
                <!-- 主图像显示窗口 -->
            </WinFormHost:WindowsFormsHost>
        </Grid>
        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExecute" Content="执行" HorizontalAlignment="Right" Margin="10 0" 
                            Command="{Binding ExecuteCommand}"
                            ToolTip="执行颜色识别"/>
                    <Button x:Name="btnCancel" Content="取消" HorizontalAlignment="Right" Margin="10 0" 
                            Click="btnCancel_Click"/>
                    <Button x:Name="btnConfirm" Content="确认" HorizontalAlignment="Right" Margin="10 0" 
                         Command="{Binding ConfirmCommand, Mode=OneTime}"
                         Background="#FFFF2000" BorderBrush="#FFFF2000"
                         ToolTip="确认并关闭窗口"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>