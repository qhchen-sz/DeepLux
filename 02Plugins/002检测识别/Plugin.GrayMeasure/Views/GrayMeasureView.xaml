<vb:ModuleViewBase x:Class="Plugin.GrayMeasure.Views.GrayMeasureView"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:vb="clr-namespace:HV.Core;assembly=HV"      
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:Plugin.GrayMeasure.Views"
                   xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                   xmlns:vm="clr-namespace:Plugin.GrayMeasure.ViewModels"
                   xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                   xmlns:helper="clr-namespace:HV.Common.Helper;assembly=HV"
                   xmlns:enum="clr-namespace:HV.Common.Enums;assembly=HV"
                   xmlns:cvt="clr-namespace:HV.Assets.Converter;assembly=HV"
                   xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
                   xmlns:hw="clr-namespace:VM.Halcon;assembly=VM.Halcon"
                   Icon="/Plugin.GrayMeasure;component/Assets/Images/Tool/GrayMeasure.png"
                   Height="680" Width="980"
                   Loaded="ModuleViewBase_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <cvt:EnumConverter x:Key="EnumConverter"/>
                    <cvt:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
                    <cvt:StatusConverter x:Key="StatusConverter"/>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/HV;component/Assets/Collection.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl Style="{StaticResource VerTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource VerTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="基本参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border>
                                <GroupBox Header="图像链接">
                                    <StackPanel Orientation="Horizontal" Margin="5 0">
                                        <TextBlock Text="输入图像" VerticalAlignment="Center"/>
                                        <TextBox Style="{StaticResource LinkTextBox}" Width="200" Margin="5 0"
                                                 BorderThickness="0 0 0 1" IsReadOnly="True"
                                                 Text="{Binding InputImageLinkText}"
                                                 mah:TextBoxHelper.LinkButtonCommand="{Binding LinkCommand,Mode=OneWay}"
                                                 mah:TextBoxHelper.LinkButtonCommandParameter="{x:Static vm:eLinkCommand.InputImageLink}"/>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                            <Border Grid.Row="1">
                                <GroupBox Header="ROI信息">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="圆心X:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding CenterX}" Minimum="0" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="圆心Y:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding CenterY}" Minimum="0" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <TextBlock Text="半径:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding Radius}" Minimum="1" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <RadioButton Content="环形ROI" Margin="0 0 10 0"
                                                         IsChecked="{Binding RoiMode, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRoiMode.Circle}}"/>
                                            <RadioButton Content="圆阵ROI" Margin="0 0 10 0"
                                                         IsChecked="{Binding RoiMode, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRoiMode.CircleArray}}"/>
                                            <RadioButton Content="矩形阵ROI"
                                                         IsChecked="{Binding RoiMode, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static vm:eRoiMode.RectArray}}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.CircleArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="行数:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding ArrayRows}" Minimum="1" Maximum="100" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.CircleArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="列数:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding ArrayCols}" Minimum="1" Maximum="100" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.CircleArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="行间距:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding ArrayRowSpacing}" Minimum="1" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="矩形半长:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding RectLength1}" Minimum="1" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="矩形半宽:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding RectLength2}" Minimum="1" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="矩形角度:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding RectAngle}" Minimum="0" Interval="1"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.CircleArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="列间距:" VerticalAlignment="Center" Width="60"/>
                                            <mah:NumericUpDown Width="200" Margin="5 0"
                                                               Value="{Binding ArrayColSpacing}" Minimum="1" Interval="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="参数设置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <GroupBox Header="卡尺参数" Grid.Row="0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="卡尺长度:" VerticalAlignment="Center" Width="70"/>
                                    <mah:NumericUpDown Width="180" Margin="5 0"
                                                       Value="{Binding Length1}" Minimum="1" Interval="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="卡尺宽度:" VerticalAlignment="Center" Width="70"/>
                                    <mah:NumericUpDown Width="180" Margin="5 0"
                                                       Value="{Binding Length2}" Minimum="1" Interval="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="卡尺个数:" VerticalAlignment="Center" Width="70"/>
                                    <mah:NumericUpDown Width="180" Margin="5 0"
                                                       Value="{Binding MeasNum}" Minimum="1" Maximum="100" Interval="1"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="灰度阈值检测" Grid.Row="1" Margin="0 10 0 0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <CheckBox Content="启用" IsChecked="{Binding EnableMaxGrayCheck}" VerticalAlignment="Center"/>
                                    <TextBlock Text="最大灰度阈值:" VerticalAlignment="Center" Width="85" Margin="10 0 0 0"/>
                                    <mah:NumericUpDown Width="120" Margin="5 0"
                                                       Value="{Binding MaxGrayThreshold}" Minimum="0" Maximum="255" Interval="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <CheckBox Content="启用" IsChecked="{Binding EnableMinGrayCheck}" VerticalAlignment="Center"/>
                                    <TextBlock Text="最小灰度阈值:" VerticalAlignment="Center" Width="85" Margin="10 0 0 0"/>
                                    <mah:NumericUpDown Width="120" Margin="5 0"
                                                       Value="{Binding MinGrayThreshold}" Minimum="0" Maximum="255" Interval="1"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>
                <TabItem Header="数据结果">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border>
                            <GroupBox Header="灰度结果">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="平均灰度:" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding AverageGray, StringFormat=F2}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="最大灰度:" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding MaxGray, StringFormat=F2}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="最小灰度:" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Width="180" Margin="5 0" BorderThickness="0 0 0 1"
                                                 Text="{Binding MinGray, StringFormat=F2}" IsReadOnly="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                        <Border Grid.Row="1">
                            <GroupBox Header="显示设置">
                                <StackPanel>
                                    <CheckBox Content="显示卡尺区域" IsChecked="{Binding ShowMeasContour}" Margin="5"/>
                                    <CheckBox Content="显示灰度值" IsChecked="{Binding ShowGrayValue}" Margin="5"/>
                                    <CheckBox Content="显示测量圆" IsChecked="{Binding ShowCirclePath}" Margin="5"/>
                                    <CheckBox Content="显示阵列" IsChecked="{Binding ShowCircleArray}" Margin="5">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.CircleArray}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RoiMode}" Value="{x:Static vm:eRoiMode.RectArray}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </StackPanel>
                            </GroupBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1"/>
            <WinFormHost:WindowsFormsHost Margin="5" Grid.Column="2" x:Name="winFormHost"/>
        </Grid>
        <Border Grid.Row="1" BorderBrush="White" BorderThickness="0 0.5 0 0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/><Run Text="{Binding ModuleParam.ElapsedTime}"/><Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="状态:"/>
                        <Run Text="{Binding ModuleParam.Status,Converter={StaticResource StatusConverter}}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="执行" Margin="10 0" Command="{Binding ExecuteCommand}"/>
                    <Button Content="取消" Margin="10 0" Click="btnCancel_Click"/>
                    <Button Content="确认" Margin="10 0" Command="{Binding ConfirmCommand}"
                            Background="#FFFF2000" BorderBrush="#FFFF2000"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</vb:ModuleViewBase>
